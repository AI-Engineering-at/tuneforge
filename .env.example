# TuneForge public repo example environment
# Copy this file to .env locally and fill only the variables you actually use.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
HF_TOKEN=
GGUF_CONVERTER=python3 -m llama_cpp.convert
TUNEFORGE_DOCKER_IMAGE=ghcr.io/ai-engineerings-at/tuneforge-studio:technical-preview

# --- TurboQuant Inference Engine ---
TURBOQUANT_API_BASE=http://turboquant:8182/v1
TURBOQUANT_MODEL_REPO=bartowski/mistralai_Mistral-Small-3.2-24B-Instruct-2506-GGUF
TURBOQUANT_MODEL_FILE=mistralai_Mistral-Small-3.2-24B-Instruct-2506-Q4_K_M.gguf
